{
  "name": "pre-release-database-cdb",
  "description": "YGOPro super pre cards",
  "version": "1.0.0",
  "scripts": {
    "lint": "eslint --fix .",
    "prepare:ygopro": "ts-node scripts/prepare-ygopro.ts",
    "prepare:ref": "ts-node scripts/prepare-ref.ts",
    "generate:pre-release-code2name": "ts-node scripts/generate-pre-release-code2name.ts",
    "check:redtext": "ts-node scripts/check-redtext.ts",
